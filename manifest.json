{
  "manifest_version": 3,
  "name": "WhatsApp → Salesforce | Grupo Cometa",
  "version": "2.7.0",
  "description": "Captura dados do WhatsApp Web e envia ao Salesforce via wz-api",
  "key": "",
  "permissions": ["activeTab", "storage", "identity", "tabs"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "http://localhost:3000/*",
    "https://cometa--crm.sandbox.lightning.force.com/*",
    "https://cometa--crm.sandbox.my.salesforce.com/*",
    "https://test.salesforce.com/*",
    "https://*.salesforce.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js",
        "fonts/Geist-Regular.woff2",
        "fonts/Geist-SemiBold.woff2",
        "fonts/GeistMono-Regular.woff2"
      ],
      "matches": ["https://web.whatsapp.com/*"]
    }
  ],
  "action": {
    "default_title": "WZ → Salesforce — Abrir WhatsApp Web"
  }
}
